
#Teste Calculador de gordura corporal

import math 

nome = input("Qual o seu nome?")



def funcaoinicio():

    while True:

        resposta_inicio = input(f"Vamos medir o seu indice de gordura corporal {nome}? digite 'sim' para continuar")

        if resposta_inicio.lower() in ["sim","claro",]:
            perguntas()
            break

        else:
            print("é sim ou Sim")
        



def perguntas():
    altura = float(
        input("Qual a sua Altura?")
        )
    
    cintura = float(
        input('Qual a Circunferencia da sua cintura?')
        )
    
    pescoço = float(
        input('Qual a Circunferencia do seu pescoço?')
        )
    
    calculodegordura(altura,cintura,pescoço)




def calculodegordura(altura,cintura,pescoço):
    gordura = (86.010 * math.log10(cintura - pescoço) - 70.041 * math.log10(altura) + 36.76)
    print(f"Sua gordura corporal é de {round(gordura,2)}%")
    
    
